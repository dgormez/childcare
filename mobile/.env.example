# ── API ───────────────────────────────────────────────────────────────────────
# Local dev: http://YOUR_LAN_IP:5001  (find with `ipconfig getifaddr en0` on macOS)
# Production: https://your-cloudrun-url.run.app
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:5001

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_GOOGLE_ANDROID_CLIENT_ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID

# ── Sentry (optional — crash reporting) ──────────────────────────────────────
# Create a project at https://sentry.io → React Native → copy the DSN
EXPO_PUBLIC_SENTRY_DSN=
