{
  "name": "childcare-parent",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --watchAll=false",
    "test:watch": "jest",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "build:ios:prod": "eas build --platform ios --profile production",
    "update": "eas update --branch production",
    "generate-api-client": "openapi-typescript ${EXPO_PUBLIC_API_BASE_URL:-http://localhost:5000}/openapi/v1.json -o services/generated/api-types.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.7",
    "expo-auth-session": "~7.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-linking": "~8.0.12",
    "expo-localization": "~16.0.0",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^24.2.0",
    "jest-expo": "~54.0.17",
    "lucide-react-native": "^1.23.0",
    "nativewind": "^4.1.23",
    "openapi-fetch": "^0.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.2.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.2.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.5.0",
    "test-renderer": "^1.2.0",
    "typescript": "~5.9.2"
  }
}
