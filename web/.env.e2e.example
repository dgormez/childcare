# Copy to .env.e2e (gitignored) and fill in real values before running `npm run test:e2e`.
# The web app itself is started for you by playwright.config.ts (npm run dev).
# The backend API and Postgres are NOT started for you — run `docker compose up -d` from the
# repo root and `dotnet run` in backend/ChildCare.Api first.

E2E_BASE_URL=http://localhost:3000
E2E_API_BASE_URL=http://localhost:5001

# backend/ChildCare.Api/appsettings.Development.json -> SuperAdmin:ApiKey
E2E_SUPERADMIN_API_KEY=
