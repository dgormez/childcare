{
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_SUPABASE_CONNECTION_STRING"
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "ChildCare",
    "Audience": "ChildCareApp",
    "AccessTokenExpiryMinutes": "60",
    "RefreshTokenExpiryDays": "30"
  },
  "Apple": {
    "BundleId": "YOUR_BUNDLE_ID"
  },
  "SuperAdmin": {
    "ApiKey": "YOUR_SUPERADMIN_API_KEY"
  },
  "App": {
    "Scheme": "childcare",
    "ResetBaseUrl": "childcare://reset-password",
    "VerifyBaseUrl": "childcare://verify-email",
    "StaffInviteBaseUrl": "childcare://staff-invitation"
  },
  "Storage": {
    "ProfilePhotosBucketName": "YOUR_GCS_PROFILE_PHOTOS_BUCKET_NAME"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": "587",
    "FromAddress": "noreply@childcare.app",
    "Username": "",
    "Password": ""
  },
  "Google": {
    "AllowedClientIds": [
      "YOUR_GOOGLE_ANDROID_CLIENT_ID",
      "YOUR_GOOGLE_IOS_CLIENT_ID",
      "YOUR_GOOGLE_WEB_CLIENT_ID"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Stripe": {
    "SecretKey":     "YOUR_STRIPE_SECRET_KEY",
    "WebhookSecret": "YOUR_STRIPE_WEBHOOK_SECRET",
    "PriceId":       "YOUR_STRIPE_PRICE_ID",
    "SuccessUrl":    "childcare://payment-success",
    "CancelUrl":     "childcare://payment-cancel"
  }
}
