<h2 style="margin:0 0 16px;font-size:20px;color:#1F2937">{{ title }}</h2>
<p style="font-size:15px;line-height:1.6;color:#1F2937">{{ body }}</p>
<p style="margin:24px 0 0;padding:16px;background:#F5F3EE;border-radius:8px;font-size:14px;color:#1F2937">
  {{ reference_label }}: <strong style="font-family:ui-monospace,monospace">{{ reference_code }}</strong>
</p>
